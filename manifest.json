{
  "manifest_version": 3,
  "name": "CopyURL - YouTube Thumbnail URL Copier",
  "version": "1.0.0",
  "description": "Hover over a YouTube video thumbnail and press Alt+X to copy its clean URL.",
  "permissions": ["clipboardWrite"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
